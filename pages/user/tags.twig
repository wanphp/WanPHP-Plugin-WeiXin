<div data-page="wx.user.tags" class="card"
     hx-get="{{ url_for('wx.user.tags') }}" hx-trigger="refresh-page from:body"
     hx-target="this" hx-swap="outerHTML">
  <div class="card-header">
    <h3 class="card-title">{{ title }}</h3>

    <div class="card-tools">
      <div class="btn-group">
        <button id="addTag" type="button" class="btn btn-tool" data-action="{{ url_for('wx.user.tag.create') }}"
                data-bs-toggle="tooltip" data-bs-title="添加标签"><i class="fas fa-plus-circle"></i>添加
        </button>
      </div>
    </div>
  </div>
  <div class="card-body">
    <table class="table table-sm table-bordered table-hover">
      <thead>
      <tr>
        <th>ID</th>
        <th>标签</th>
        <th>粉丝数({{ total }})</th>
        <th>操作</th>
      </tr>
      </thead>
      <tbody>
      {% for tag in tags %}
        <tr>
          <td>{{ tag.id }}</td>
          <td>{{ tag.name }}</td>
          <td>{{ tag.count }}</td>
          <td>
            <button type="button" class="btn btn-tool edit"
                    data-action="{{ url_for('wx.user.tag.update', {id:tag.id}) }}"
                    data-name="{{ tag.name }}"
                    data-bs-toggle="tooltip" data-bs-title="修改">
              <i class="fas fa-edit"></i></button>
            <button type="button" class="btn btn-tool delete"
                    data-action="{{ url_for('wx.user.tag.delete', {id:tag.id}) }}"
                    data-bs-toggle="tooltip" data-bs-title="删除">
              <i class="fas fa-trash-alt"></i></button>
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
  <!-- /.card-body -->
</div>
<!-- /.card -->
