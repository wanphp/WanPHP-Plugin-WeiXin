<div data-page="wx.custom_menu.add" class="card">
  <div class="card-header">
    <h3 class="card-title">{{ title }}</h3>
  </div>
  <div class="card-body">
    <form hx-post="{{ action }}"
          hx-swap="none"
          hx-headers='{"HX-Trigger": "refresh-page"}'
          hx-target="this"
          class="needs-validation"
          data-reset
          novalidate>
      <div class="form-group mb-3">
        <input name="parent_id" type="hidden" value="{{ parent_id?:menu.parent_id }}">
        <input name="tag_id" type="hidden" value="{{ tag_id?:menu.tag_id }}">
        <label for="name">菜单名称</label>
        <input name="name" type="text" value="{{ menu.name }}" class="form-control" required placeholder="菜单名称" id="name"
               autocomplete="off">
      </div>
      <div class="form-group mb-3">
        <label for="type">类型</label>
        <select id="type" name="type" class="form-control" required>
          <option value="click"{{ (menu.type == 'click') ? ' selected':'' }}>点击推事件</option>
          <option value="view"{{ (menu.type == 'view') ? ' selected':'' }}>跳转URL</option>
          <option value="miniprogram"{{ (menu.type == 'miniprogram') ? ' selected':'' }}>小程序</option>
          <option value="scancode_push"{{ (menu.type == 'scancode_push') ? ' selected':'' }}>扫码推事件</option>
          <option value="scancode_waitmsg"{{ (menu.type == 'scancode_waitmsg') ? ' selected':'' }}>
            扫码推事件且弹出“消息接收中”提示框
          </option>
          <option value="pic_sysphoto"{{ (menu.type == 'pic_sysphoto') ? ' selected':'' }}>弹出系统拍照发图</option>
          <option value="pic_photo_or_album"{{ (menu.type == 'pic_photo_or_album') ? ' selected':'' }}>
            弹出拍照或者相册发图
          </option>
          <option value="pic_weixin"{{ (menu.type == 'pic_weixin') ? ' selected':'' }}>弹出微信相册发图器</option>
          <option value="location_select"{{ (menu.type == 'location_select') ? ' selected':'' }}>弹出地理位置选择器
          </option>
        </select>
      </div>
      <div class="form-group key mb-3" style="display: {{ (menu.type == 'miniprogram' or menu.type == 'view') ? 'none':'block' }}">
        <label for="key">菜单KEY值</label>
        <input id="key" name="key" type="text" value="{{ menu.key }}" class="form-control" placeholder="菜单KEY值">
      </div>
      <div class="form-group url mb-3" style="display: {{ (menu.type == 'miniprogram' or menu.type == 'view') ? 'block':'none' }}">
        <label for="url">菜单链接</label>
        <input id="url" name="url" type="text" value="{{ menu.url }}" class="form-control" placeholder="菜单链接">
      </div>
      <div class="form-group miniprogram mb-3" style="display: {{ (menu.type == 'miniprogram') ? 'block':'none' }}">
        <label for="appid">小程序的appid</label>
        <input id="appid" name="appid" type="text" value="{{ menu.appid }}" class="form-control" placeholder="小程序的appid">
      </div>
      <div class="form-group miniprogram mb-3" style="display: {{ (menu.type == 'miniprogram') ? 'block':'none' }}">
        <label for="pagepath">小程序的页面路径</label>
        <input id="pagepath" name="pagepath" type="text" value="{{ menu.pagepath }}" class="form-control"
               placeholder="小程序的页面路径">
      </div>
      <div class="form-group">
        <label for="sortOrder">显示排序</label>
        <input id="sortOrder" name="sortOrder" type="number" value="{{ menu.sortOrder }}" required class="form-control"
               placeholder="显示排序">
      </div>
      <div class="d-grid gap-2 mt-3 d-md-block">
        <button type="submit" class="btn btn-outline-primary mr-2">提交</button>
        {% if menu %}
          <span role="button" data-action="{{ url_for('wx.custom_menu.delete',{id:menu.id}) }}"
                class="btn btn-outline-danger">删除</span>
        {% endif %}
      </div>
    </form>
  </div>
</div>