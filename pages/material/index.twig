<div data-page="wx.material" class="card">
  <div class="card-header">
    <h3 class="card-title">{{ title }}</h3>
    <div class="card-tools" data-upload-action="{{ url_for('app.file.upload') }}">
      <div class="btn-group mr-2">
        <button class="btn btn-outline-success btn-sm" data-type="image">图片</button>
        <button class="btn btn-outline-primary btn-sm" data-type="uploadImage"
                data-action="{{ url_for('wx.material.add',{type:'image'}) }}"
                data-bs-toggle="tooltip" data-bs-title="添加图片">
          <i class="fas fa-plus-circle"></i>
        </button>
      </div>
      <div class="btn-group mr-2">
        <button class="btn btn-outline-info btn-sm" data-type="voice">音频</button>
        <button class="btn btn-outline-primary btn-sm" data-type="uploadVoice"
                data-action="{{ url_for('wx.material.add',{type:'voice'}) }}"
                data-bs-toggle="tooltip" data-bs-title="添加音频">
          <i class="fas fa-plus-circle"></i>
        </button>
      </div>
      <div class="btn-group mr-2">
        <button class="btn btn-outline-info btn-sm" data-type="video">视频</button>
        <button class="btn btn-outline-primary btn-sm" data-type="uploadVideo"
                data-action="{{ url_for('wx.material.add',{type:'video'}) }}"
                data-bs-toggle="tooltip" data-bs-title="添加视频">
          <i class="fas fa-plus-circle"></i>
        </button>
      </div>
    </div>
  </div>
  <div class="card-body">
    <table id="material-table" data-action="{{ action }}" class="table table-bordered"></table>
  </div>
  <!-- /.card-body -->
</div>
<!-- /.card -->

